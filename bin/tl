#!/usr/bin/env node
// tl — CLI 진입점

import fs from 'fs';
import path from 'path';
import os from 'os';
import { spawn } from 'child_process';

function getConfigDir(): string {
  return process.env.TL_CONFIG_DIR || path.join(os.homedir(), '.tl');
}

function getPidPath(): string {
  return path.join(getConfigDir(), 'daemon.pid');
}

function getBinDir(): string {
  // bin/ 디렉토리 경로 (현재 파일의 상위 디렉토리)
  return path.dirname(new URL(import.meta.url).pathname);
}

function getProjectRoot(): string {
  return path.resolve(getBinDir(), '..');
}

const command = process.argv[2];
const args = process.argv.slice(3);

async function main() {
  switch (command) {
    case 'start':
      return cmdStart();
    case 'stop':
      return cmdStop();
    case 'status':
      return cmdStatus();
    case 'init':
      return cmdInit();
    case 'config':
      return cmdConfig(args);
    case 'hook-session-start':
      return cmdHookSessionStart();
    case 'hook-stop-and-wait':
      return cmdHookStopAndWait();
    case 'help':
    case undefined:
      return cmdHelp();
    default:
      console.error(`Unknown command: ${command}`);
      cmdHelp();
      process.exit(1);
  }
}

// ===== tl start =====
function cmdStart() {
  const pidPath = getPidPath();

  // 이미 실행 중인지 확인
  if (fs.existsSync(pidPath)) {
    const existingPid = parseInt(fs.readFileSync(pidPath, 'utf-8').trim(), 10);
    try {
      process.kill(existingPid, 0);
      console.log(`Daemon already running (PID: ${existingPid})`);
      process.exit(1);
    } catch {
      // stale PID
      fs.unlinkSync(pidPath);
    }
  }

  const configDir = getConfigDir();
  if (!fs.existsSync(configDir)) {
    fs.mkdirSync(configDir, { recursive: true });
  }

  const daemonPath = path.join(getProjectRoot(), 'dist', 'daemon.js');
  if (!fs.existsSync(daemonPath)) {
    console.error('Daemon not built. Run: npm run build');
    process.exit(1);
  }

  console.log('Starting tl daemon...');
  const child = spawn('node', [daemonPath], {
    detached: true,
    stdio: 'ignore',
  });
  child.unref();
  console.log(`Daemon started (PID: ${child.pid})`);
}

// ===== tl stop =====
function cmdStop() {
  const pidPath = getPidPath();
  if (!fs.existsSync(pidPath)) {
    console.log('Daemon is not running');
    return;
  }

  const pid = parseInt(fs.readFileSync(pidPath, 'utf-8').trim(), 10);
  try {
    process.kill(pid, 'SIGTERM');
    console.log(`Sent SIGTERM to daemon (PID: ${pid})`);
  } catch {
    fs.unlinkSync(pidPath);
    console.log('Daemon was not running (stale PID file removed)');
  }
}

// ===== tl status =====
async function cmdStatus() {
  const pidPath = getPidPath();
  if (!fs.existsSync(pidPath)) {
    console.log('Daemon is not running');
    return;
  }

  const pid = parseInt(fs.readFileSync(pidPath, 'utf-8').trim(), 10);
  try {
    process.kill(pid, 0);
    console.log(`Daemon is running (PID: ${pid})`);
  } catch {
    console.log('Daemon is not running (stale PID file)');
    fs.unlinkSync(pidPath);
    return;
  }

  // HTTP 상태 조회
  const configPath = path.join(getConfigDir(), 'config.json');
  let port = 9877;
  if (fs.existsSync(configPath)) {
    try {
      const config = JSON.parse(fs.readFileSync(configPath, 'utf-8'));
      port = config.hookPort || 9877;
    } catch {
      // 무시
    }
  }

  try {
    const res = await fetch(`http://localhost:${port}/status`);
    const status = await res.json();
    console.log(`  Uptime: ${status.uptime_seconds}s`);
    console.log(`  Active sessions: ${status.active_sessions}`);
    console.log(`  Waiting sessions: ${status.waiting_sessions}`);
  } catch {
    console.log('  (Could not reach daemon HTTP endpoint)');
  }
}

// ===== tl init =====
function cmdInit() {
  const templatePath = path.join(getProjectRoot(), 'templates', 'hooks.json');
  const targetPath = path.join(os.homedir(), '.codex', 'hooks.json');

  if (!fs.existsSync(templatePath)) {
    console.error('hooks.json template not found');
    process.exit(1);
  }

  const force = args.includes('--force');

  if (fs.existsSync(targetPath) && !force) {
    console.log(`hooks.json already exists at ${targetPath}`);
    console.log('Use --force to overwrite');
    return;
  }

  const targetDir = path.dirname(targetPath);
  if (!fs.existsSync(targetDir)) {
    fs.mkdirSync(targetDir, { recursive: true });
  }

  fs.copyFileSync(templatePath, targetPath);
  console.log(`hooks.json installed to ${targetPath}`);
}

// ===== tl config =====
function cmdConfig(args: string[]) {
  const subcommand = args[0];
  const configPath = path.join(getConfigDir(), 'config.json');

  if (subcommand === 'get') {
    const key = args[1];
    if (!fs.existsSync(configPath)) {
      console.log('No config file found');
      return;
    }
    const config = JSON.parse(fs.readFileSync(configPath, 'utf-8'));
    if (key) {
      console.log(config[key] ?? '');
    } else {
      console.log(JSON.stringify(config, null, 2));
    }
    return;
  }

  if (subcommand === 'set') {
    const parts = args.slice(1);
    let config: Record<string, any> = {};
    if (fs.existsSync(configPath)) {
      config = JSON.parse(fs.readFileSync(configPath, 'utf-8'));
    }

    for (const part of parts) {
      const [key, ...valueParts] = part.split('=');
      const value = valueParts.join('=');
      if (!key || value === undefined) {
        console.error(`Invalid format: ${part}. Use KEY=VALUE`);
        process.exit(1);
      }

      // 타입 변환
      if (value === 'true') config[key] = true;
      else if (value === 'false') config[key] = false;
      else if (!isNaN(Number(value))) config[key] = Number(value);
      else config[key] = value;
    }

    if (!fs.existsSync(getConfigDir())) {
      fs.mkdirSync(getConfigDir(), { recursive: true });
    }

    fs.writeFileSync(configPath, JSON.stringify(config, null, 2), 'utf-8');
    console.log('Config saved');
    return;
  }

  console.log('Usage: tl config get [KEY] | tl config set KEY=VALUE');
}

// ===== tl hook-session-start =====
async function cmdHookSessionStart() {
  const configPath = path.join(getConfigDir(), 'config.json');
  let port = 9877;
  if (fs.existsSync(configPath)) {
    try {
      const config = JSON.parse(fs.readFileSync(configPath, 'utf-8'));
      port = config.hookPort || 9877;
    } catch {
      // 무시
    }
  }

  // stdin 읽기
  const stdin = fs.readFileSync(0, 'utf-8');
  if (!stdin.trim()) {
    console.error('No input on stdin');
    process.exit(1);
  }

  try {
    const res = await fetch(`http://localhost:${port}/hook/session-start`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: stdin,
    });

    const data = await res.json();
    if (!res.ok) {
      console.error(`HTTP ${res.status}: ${JSON.stringify(data)}`);
      process.exit(1);
    }

    console.log(
      `Session started: ${data.session_id} (topic: ${data.topic_id})`
    );
  } catch (err) {
    console.error(`Failed to connect to daemon: ${(err as Error).message}`);
    process.exit(1);
  }
}

// ===== tl hook-stop-and-wait =====
async function cmdHookStopAndWait() {
  const configPath = path.join(getConfigDir(), 'config.json');
  let port = 9877;
  if (fs.existsSync(configPath)) {
    try {
      const config = JSON.parse(fs.readFileSync(configPath, 'utf-8'));
      port = config.hookPort || 9877;
    } catch {
      // 무시
    }
  }

  // stdin 읽기
  const stdin = fs.readFileSync(0, 'utf-8');
  if (!stdin.trim()) {
    console.error('No input on stdin');
    process.exit(1);
  }

  try {
    const res = await fetch(`http://localhost:${port}/hook/stop-and-wait`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: stdin,
      // long-polling: 타임아웃 길게
      signal: AbortSignal.timeout(3700 * 1000), // 3700초 (서버 timeout + 여유)
    });

    const data = await res.json();

    if (!res.ok) {
      // SESSION_NOT_FOUND 등은 continue로 처리
      console.error(`Warning: HTTP ${res.status}: ${JSON.stringify(data)}`);
      console.log(JSON.stringify({ decision: 'continue' }));
      process.exit(0);
    }

    // HookOutput을 stdout으로 출력
    console.log(JSON.stringify(data));
    process.exit(0);
  } catch (err) {
    // 연결 끊김 등은 continue로 처리
    console.error(
      `Warning: Hook connection failed: ${(err as Error).message}`
    );
    console.log(JSON.stringify({ decision: 'continue' }));
    process.exit(0);
  }
}

// ===== tl help =====
function cmdHelp() {
  console.log(`
tl — Codex ↔ Telegram Bridge

Usage:
  tl start                     Start the daemon
  tl stop                      Stop the daemon
  tl status                    Show daemon status
  tl init [--force]            Install hooks.json to ~/.codex/
  tl config get [KEY]          Show config
  tl config set KEY=VALUE      Set config value
  tl help                      Show this help

Internal (used by Codex hooks):
  tl hook-session-start        Handle SessionStart hook (stdin → HTTP POST)
  tl hook-stop-and-wait        Handle Stop hook (stdin → POST → long-poll → stdout)
`);
}

main().catch((err) => {
  console.error(`Fatal: ${err.message}`);
  process.exit(1);
});
